# ════════════════════════════════════════════════════
# howu 環境變數範本 — 複製為 .env.local 後填入實際值
# .env* 已被 .gitignore,key 千萬不要 commit
# ════════════════════════════════════════════════════

# ───── Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───── Site
NEXT_PUBLIC_SITE_URL=https://howu.online

# ───── Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ───── LINE Pay
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=

# ───── 街口支付
JKOPAY_MERCHANT_ID=
JKOPAY_API_KEY=

# ───── OpenAI(後端代理,絕不可進前端 bundle)
OPENAI_API_KEY=

# ───── Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@howu.online

# ───── OneSignal(備援推播)
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ───── Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ───── PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ───── ezPay 雲端發票
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=
EZPAY_HASH_IV=
